# Root .gitignore for float-bank project

# Dependencies
node_modules/
vendor/

# Build outputs
dist/
bin/
tmp/
out-tsc/
bazel-out/
*.exe
*.exe~
*.dll
*.so
*.dylib

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
.history/

# Environment files
.env
*.env.local
*.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Angular specific
.angular/
.sass-cache/
connect.lock
coverage/
libpeerconnection.log
testem.log
typings/
__screenshots__/

# System Files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Go specific
backend/tmp/
backend/bin/
backend/*.exe
